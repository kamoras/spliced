{
  "name": "spliced",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A daily music puzzle: reassemble a shuffled song clip from its spliced pieces.",
  "license": "MIT",
  "author": "Ryan Mack",
  "homepage": "https://github.com/kamoras/spliced#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamoras/spliced.git"
  },
  "bugs": {
    "url": "https://github.com/kamoras/spliced/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:catalog": "node scripts/build-catalog.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
